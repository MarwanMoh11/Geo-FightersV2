{
  "name": "geofighters-2.0",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "A high-performance 3D arcade shooter built with Three.js and Miniplex.",
  "author": "Marwan",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{ts,tsx,svelte,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,svelte,css}\"",
    "check": "svelte-check --tsconfig ./tsconfig.json"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/three": "^0.182.0",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "prettier-plugin-svelte": "^4.1.0",
    "svelte": "^5.46.1",
    "svelte-check": "^4.6.0",
    "svelte-preprocess": "^6.0.3",
    "typescript": "~5.9.3",
    "vite": "^7.2.4"
  },
  "dependencies": {
    "miniplex": "^2.0.0",
    "three": "^0.182.0"
  }
}
